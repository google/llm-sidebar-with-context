{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    // Extension source runs in the browser: DOM + Chrome APIs only.
    // Node globals (process, Buffer, ...) must not be referenced here;
    // build-time-inlined env vars are declared in env.d.ts.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome", "marked"]
  },
  "include": ["**/*"]
}
